#!/bin/bash
# ABOUTME: Pre-commit hook for security scanning
# ABOUTME: Runs Bandit SAST and basic security checks

set -e

echo "🔍 Running security checks..."

# 1. Bandit SAST scan
echo "🐍 Running Bandit SAST..."
if command -v bandit &> /dev/null; then
    bandit -r src/ -ll -q || {
        echo "❌ Bandit found security issues!"
        exit 1
    }
fi

echo "✅ All security checks passed!"
exit 0
